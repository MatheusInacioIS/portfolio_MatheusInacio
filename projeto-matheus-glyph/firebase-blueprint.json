{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific settings and profile data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth ID." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile picture URL." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "SavedGlyph": {
      "title": "Saved Glyph",
      "description": "A saved QR code configuration.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the saved glyph." },
        "uid": { "type": "string", "description": "Owner's user ID." },
        "name": { "type": "string", "description": "Name given to this saved glyph." },
        "data": { "type": "string", "description": "The QR code data (URL/Text)." },
        "options": { "type": "object", "description": "The full QR code styling options." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When it was saved." }
      },
      "required": ["uid", "data", "options", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document."
    },
    "/users/{userId}/glyphs/{glyphId}": {
      "schema": "SavedGlyph",
      "description": "Collection of saved QR codes for a user."
    }
  }
}
